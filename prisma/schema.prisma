generator client {
  provider = "prisma-client-js"
}

datasource db {
  // 本地开发使用 SQLite
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id                     String         @id
  name                   String?
  email                  String?        @unique
  emailVerified          DateTime?
  image                  String?
  password               String?
  bio                    String?        // 个性签名
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @default(now()) @updatedAt
  hasCompletedOnboarding    Boolean     @default(false)
  hasCompletedNewUserGuide  Boolean     @default(false)
  heartTreeName             String?     @default("心树")
  userExp                Float          @default(0)
  userLevel              Int            @default(1)
  lastAnnouncedLevel     Int            @default(1)
  heartTreeLevel         Int            @default(1)
  heartTreeCurrentExp    Float          @default(0)
  heartTreeTotalExp      Float          @default(0)
  fruits                 Int            @default(0)     // 🍎 当前果实
  totalFruitsEarned      Int            @default(0)     // 🍎 累计获得果实
  theme                  String         @default("default")
  lastWelcomeDate        String?        // 最近一次欢迎文案触发日期 (YYYY-MM-DD)
  lastPeriodicSpiritAt   DateTime?      // 最近一次定时陪伴文案触发时间
  lastWateredDate        String?
  fertilizerExpiresAt    DateTime?
  fertilizerMultiplier   Float?
  flowMetrics            Json?          // 心流指标数据（impression, tempFlow等）
  streakDays             Int            @default(0)     // 🔥 连续专注天数
  lastStreakDate         String?                        // 🔥 最后一次更新连续天数的日期 (YYYY-MM-DD)
  echoCompanionDays      Int            @default(0)     // 🤝 Echo陪伴天数（登录累计）
  lastEchoCompanionDate  String?                        // 🤝 最后一次累计 Echo陪伴 的日期 (YYYY-MM-DD)
  totalFocusMinutes      Int            @default(0)     // 🔥 总专注时长（分钟）
  activatedAt            DateTime?                      // 首次完成专注（活跃定义）
  qualityActivatedAt     DateTime?                      // 首次质量活跃（达标专注或保存小结）
  firstSessionAt         DateTime?
  lastActiveAt           DateTime?
  timezone               String?
  totalCompletedMilestones Int          @default(0)     @map("total_completedmilestones")
  totalCompletedProjects  Int           @default(0)     @map("total_completedprojects")
  accounts               Account[]
  sessions               Session[]
  projects               Project[]
  focusSessions          FocusSession[]
  events                 Event[]
  userSessions           UserSession[]
  dailyActivities        DailyUserActivity[]
  dailyFocusStats        DailyFocusStats[]
  featureUsageDaily      FeatureUsageDaily[]
  dailySummaries         DailySummary[]
  shareLinks             ShareLink[]
  weeklyReports          WeeklyReport[]
  recoveryQuestions      RecoveryQuestion[]
  passwordResetTokens    PasswordResetToken[]
  achievements           Achievement[]
  mails                  Mail[]
  microGoalHistories     MicroGoalHistory[]

  @@index([createdAt])
  @@index([email])
}

model MicroGoalHistory {
  id             String   @id @default(cuid())
  userId         String
  rawText        String
  normalizedText String
  usageCount     Int      @default(1)
  lastUsedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedText])
  @@index([userId, lastUsedAt])
  @@index([userId, usageCount])
}

model Mail {
  id          String   @id
  userId      String
  title       String
  content     String
  date        String   // YYYY-MM-DD
  sender      String   @default("Echo 系统")
  type        String   @default("system")
  isRead      Boolean  @default(false)
  isPermanent Boolean  @default(false)
  actionUrl   String?
  actionLabel String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, isRead])
  @@index([expiresAt])
  @@map("mails")
}

model Project {
  id                    String         @id @default(cuid())
  name                  String
  description           String?
  finalGoal             Json?
  icon                  String
  color                 String?
  dailyGoalMinutes      Int            @default(25)
  targetDate            DateTime?
  isActive              Boolean        @default(true)
  isPrimary             Boolean        @default(false)  // 是否为主要计划
  isCompleted           Boolean        @default(false)  // 是否已完成
  userId                String
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  
  // 统计字段（仅在作为主要计划时增长）
  totalFocusMinutes     Int            @default(0)      // 专注总时长（分钟）
  streakDays            Int            @default(0)      // 连续天数
  lastStreakDate        String?                         // 最后一次更新连续天数的日期
  completedMilestones   Int            @default(0)      // 完成的小目标数
  startDate             DateTime?                       // 起始日期（首次作为主要计划的日期）
  avgFlowScore          Float?                          // 平均心流指数
  
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones        Milestone[]
  focusSessions     FocusSession[]
  
  @@index([userId, isPrimary])
  @@index([userId, isActive])
}

model Milestone {
  id        String   @id @default(cuid())
  title     String
  isCompleted Boolean @default(false)
  order     Int
  projectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model FocusSession {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime?
  duration  Int      // 分钟
  note      String?
  rating    Int?
  flowIndex Int?
  expEarned Int?
  deviceType String?
  timeBucket String?
  startHourBucket String?
  sessionLengthBucket String?
  hadDistraction Boolean @default(false)
  hadTabHide Boolean @default(false)
  hadIdle Boolean @default(false)
  hadRapidSwitch Boolean @default(false)
  resumeCount Int @default(0)
  goalMinutes Int?
  isMinMet  Boolean  @default(false)
  goalSource String?
  targetMilestoneId String?
  projectId String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startTime])
  @@index([userId, createdAt])
}

model Event {
  id             String   @id @default(cuid())
  userId         String?
  sessionId      String?
  name           String
  feature        String?
  page           String?
  action         String?
  properties     Json?
  clientTime     DateTime?
  timezone       String?
  dateKey        String
  idempotencyKey String?  @unique
  createdAt      DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, dateKey])
  @@index([name, dateKey])
  @@index([feature, dateKey])
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  sessionId   String   @unique
  startedAt   DateTime
  endedAt     DateTime?
  durationSec Int?
  entryPage   String?
  device      String?
  timezone    String?
  dateKey     String
  hasPlan     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dateKey])
}

model DailyUserActivity {
  id            String   @id @default(cuid())
  userId        String
  dateKey       String
  firstEventAt  DateTime
  lastEventAt   DateTime
  sessionCount  Int      @default(0)
  eventCount    Int      @default(0)
  active        Boolean  @default(false)
  qualityActive Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([dateKey])
}

model DailyFocusStats {
  id                    String   @id @default(cuid())
  userId                String
  dateKey               String
  focusMinutes          Int      @default(0)
  focusSessionCount     Int      @default(0)
  qualifiedSessionCount Int      @default(0)
  qualifiedDay          Boolean  @default(false)
  companionDay          Boolean  @default(false)
  flowScoreSum          Int      @default(0)
  flowScoreCount        Int      @default(0)
  flowScoreAvg          Float?
  firstFocusAt          DateTime?
  lastFocusAt           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@index([dateKey])
}

model FeatureUsageDaily {
  id        String   @id @default(cuid())
  userId    String
  dateKey   String
  feature   String
  count     Int      @default(0)
  firstAt   DateTime?
  lastAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey, feature])
  @@index([feature, dateKey])
}

model Comment {
  id        String   @id @default(cuid())
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comments")
}

model DailySummary {
  id                 String   @id @default(cuid())
  userId             String
  date               String   // YYYY-MM-DD
  text               String
  totalFocusMinutes  Int      @default(0)
  completedTaskCount Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareLinks         ShareLink[]

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
}

model ShareLink {
  id        String   @id @default(cuid())
  userId    String
  summaryId String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime?
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary   DailySummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)

  @@index([token])
}

model WeeklyReport {
  id          String   @id @default(cuid())
  userId      String
  weekStart   DateTime
  weekEnd     DateTime
  totalMinutes Int
  wowChange   Float?
  streakDays  Int      @default(0)
  bestDay     DateTime?
  bestDayNote String?
  flowAvg     Int?
  flowDelta   Float?
  expTotal    Int?
  payloadJson Json
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([expiresAt])
}

model RecoveryQuestion {
  id         String   @id @default(cuid())
  userId     String
  question   String
  answerHash String
  salt       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Achievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  category      String
  unlockedAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("achievements_unlocked")
}

model ShopPurchase {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemType  String
  price     Int
  createdAt DateTime @default(now())

  @@unique([userId, itemId])
  @@index([userId])
  @@map("shop_purchases")
}
